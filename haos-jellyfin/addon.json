{
  "name": "Jellyfin Media Server",
  "version": "10.9.0",
  "slug": "jellyfin",
  "description": "Jellyfin - The Free Software Media Server with Hardware Acceleration (VA-API/Vulkan)",
  "url": "https://github.com/thcuba/haos-jellyfin",
  "arch": ["amd64", "aarch64"],
  "startup": "service",
  "boot": "auto",
  "ports": {
    "8096/tcp": 8096
  },
  "devices": [
    "/dev/dri:/dev/dri:rwm"
  ],
  "environment": {
    "LIBVA_DRIVER_NAME": "iHD"
  },
  "options": {
    "log_level": "info",
    "host": "0.0.0.0",
    "port": 8096
  },
  "schema": {
    "log_level": "select",
    "host": "str",
    "port": "port"
  },
  "privileged": ["NET_ADMIN"],
  "homeassistant_api": false,
  "services": []
}
