{
  "name": "Jellyfin Media Server",
  "version": "10.11.11",
  "slug": "jellyfin",
  "description": "Jellyfin - The Free Software Media Server with Hardware Acceleration (VA-API/Vulkan)",
  "url": "https://github.com/thcuba/haos-jellyfin",
  "codeowners": ["@thcuba"],
  "documentation": "https://github.com/thcuba/haos-jellyfin",
  "issue_tracker": "https://github.com/thcuba/haos-jellyfin/issues",
  "homeassistant": "2024.1.0",
  "image": "ghcr.io/thcuba/haos-jellyfin-{arch}",
  "arch": ["amd64", "aarch64"],
  "startup": "service",
  "boot": "auto",
  "ports": {
    "8096/tcp": 8096
  },
  "devices": [
    "/dev/dri:/dev/dri:rwm"
  ],
  "environment": {
    "LIBVA_DRIVER_NAME": "iHD"
  }
}
